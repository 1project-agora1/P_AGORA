// client type
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

// DB type
// MySQL
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------------------------------------------------
// User
model User {
  id             BigInt   @id @default(autoincrement())
  token          String   @unique
  nickname       String   
  password       String   @db.VarChar(128)
  email          String   @unique
  email_verified Boolean  @default(false)
  role           UserRole @default(ROLE_USER)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  posts          Post[]

  @@map("user")
}
// UserRole
enum UserRole {
  ROLE_DEVELOPER
  ROLE_ADMIN
  ROLE_USER
}

// ---------------------------------------------------------------------------------------------------------------------
// Post
model Post {
  id                 BigInt      @id @default(autoincrement())
  token              String      @unique
  channel_item_token String
  title              String
  content            String      @db.Text
  user_token         String
  views              Int         @default(0)
  likes              Int         @default(0)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  channel_item       ChannelItem @relation(fields: [channel_item_token], references: [token])
  user               User        @relation(fields: [user_token], references: [token])

  @@index([channel_item_token], map: "post_channel_item_token_fkey")
  @@index([user_token], map: "post_user_token_fkey")
  @@map("post")
}

// ---------------------------------------------------------------------------------------------------------------------
// Channel
model Channel {
  id           BigInt        @id @default(autoincrement())
  token        String        @unique
  menu_name    String
  url          String
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  channelItems ChannelItem[]

  @@map("channel")
}

// ---------------------------------------------------------------------------------------------------------------------
// ChannelItem
model ChannelItem {
  id                   BigInt        @id @default(autoincrement())
  token                String        @unique
  parent_menu_token    String
  parent_submenu_token String?
  submenu_name         String
  url                  String
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  channel              Channel       @relation(fields: [parent_menu_token], references: [token])
  parent               ChannelItem?  @relation("ParentSubmenu", fields: [parent_submenu_token], references: [token])
  children             ChannelItem[] @relation("ParentSubmenu")
  Post                 Post[]

  @@index([parent_menu_token], map: "channel_item_parent_menu_token_fkey")
  @@index([parent_submenu_token], map: "channel_item_parent_submenu_token_fkey")
  @@map("channel_item")
}

// ---------------------------------------------------------------------------------------------------------------------
// ViewLog
model ViewLog {
  token      String   @unique
  ip         String
  post_token String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@id([ip, post_token])
  @@map("view_log")
}

// ---------------------------------------------------------------------------------------------------------------------
// LikeLog
model like_log {
  token      String   @unique
  user_token String
  post_token String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@id([user_token, post_token])
  @@map("like_log")
}


model SYS_USER {
  SU_ID    String    @id @db.VarChar(50)
  SU_PW    String?   @db.VarChar(45)
  SU_NAME  String?   @db.VarChar(45)
  SU_PHON  String?   @db.VarChar(45)
  SU_EMAIL String?   @db.VarChar(45)
  SU_TYPE  String?   @db.VarChar(45)
  SU_BRAND String?   @db.VarChar(45)
  SU_STORE String?   @db.VarChar(45)
  SU_USEYN String?   @db.VarChar(45)
  SU_INID  String?   @db.VarChar(45)
  SU_INDT  DateTime? @db.DateTime(0)
  SU_UPID  String?   @db.VarChar(45)
  SU_UPDT  DateTime? @db.DateTime(0)

  @@ignore
}
