// client type
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

// DB type
// MySQL
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------------------------------------------------
// User
model User {
  id             BigInt   @id @default(autoincrement())
  token          String   @unique // TODO: 이메일 인증을 위한 토큰
  nickname       String   @unique // TODO: 닉네임 길이 제한 필요
  password       String   @db.VarChar(128)
  email          String   @unique
  email_verified Boolean  @default(false)
  role           UserRole @default(ROLE_USER) // 초기 값 : 일반 유저
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // mapping - User 1 : N Post
  posts Post[]

  @@map("user")
}

// UserRole - enum
enum UserRole {
  ROLE_DEVELOPER // 개발자 - 모든 권한
  ROLE_ADMIN // 관리자 - 개발 제외 모든 운영 권한
  ROLE_USER // 유저 - 일반 활동 관련 권한
}

// ---------------------------------------------------------------------------------------------------------------------
// Post
model Post {
  id                 BigInt   @id @default(autoincrement())
  token              String   @unique // 게시판 글 토큰
  channel_item_token String
  title              String
  content            String   @db.Text
  user_token         String // 유저 테이블 매핑을 위한 FK
  views              Int      @default(0)
  likes              Int      @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // mapping - FK : user_token
  user User @relation(fields: [user_token], references: [token])
  channel_item ChannelItem @relation(fields: [channel_item_token], references: [token])

  @@map("post")
}

// PostType - enum
enum PostType {
  TEXT_ONLY // 글자만
  MEDIA_ONLY // 미디어만
  TEXT_MEDIA // 글자, 미디어 둘 다 존재
}

// ---------------------------------------------------------------------------------------------------------------------
// Channel
model Channel {
  id        BigInt   @id @default(autoincrement())
  token     String   @unique
  menu_name String
  url       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // mapping - Channel 1 : N ChannelItem
  channelItems ChannelItem[]

  @@map("channel")
}

// ---------------------------------------------------------------------------------------------------------------------
// ChannelItem
model ChannelItem {
  id                   BigInt   @id @default(autoincrement())
  token                String   @unique
  parent_menu_token    String
  parent_submenu_token String?
  submenu_name         String
  url                  String
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // mapping - FK : parent_menu_token
  channel  Channel       @relation(fields: [parent_menu_token], references: [token])
  // mapping - FK : parent_submenu_token
  parent   ChannelItem?  @relation("ParentSubmenu", fields: [parent_submenu_token], references: [token])
  children ChannelItem[] @relation("ParentSubmenu")

  @@map("channel_item")
  Post Post[]
}

// ---------------------------------------------------------------------------------------------------------------------
// ViewLog
model ViewLog {
  token     String   @unique
  ip        String
  post_token String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@id([ip, post_token])

    @@map("view_log")
}